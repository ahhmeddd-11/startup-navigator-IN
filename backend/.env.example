# Django configuration
DJANGO_SECRET_KEY=django-insecure-replace-this-with-a-secure-key-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# Database configuration (MySQL is mandatory)
DB_NAME=startup_navigator
DB_USER=root
DB_PASSWORD=root_password_here
DB_HOST=127.0.0.1
DB_PORT=3306

# CORS configuration
# Comma-separated list of origins
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# JWT configuration
# If empty, simple_jwt will fallback to Django's SECRET_KEY
JWT_SECRET_KEY=jwt-secret-key-replace-this-with-a-secure-key-in-production

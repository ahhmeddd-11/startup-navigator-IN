# ============================================================
# Startup Navigator - Environment Variables
# ============================================================

# ----------------------------
# Django Configuration
# ----------------------------
DJANGO_SECRET_KEY=replace-with-a-secure-secret-key
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# ----------------------------
# Database
# Local Development (MySQL)
# ----------------------------
DB_NAME=startup_navigator
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_HOST=127.0.0.1
DB_PORT=3306

# ----------------------------
# Production Database
# Render PostgreSQL
# Leave empty during local development
# ----------------------------
DATABASE_URL=

# ----------------------------
# Google Gemini API
# ----------------------------
GEMINI_API_KEY=your_gemini_api_key

# ----------------------------
# JWT
# Leave blank to use Django SECRET_KEY
# ----------------------------
JWT_SECRET_KEY=

# ----------------------------
# CORS
# Comma-separated list
# ----------------------------
CORS_ALLOWED_ORIGINS=https://startup-navigator-in.vercel.app,https://www.startup-navigator-in.vercel.app
# http://localhost:5173,http://127.0.0.1:5173

# ----------------------------
# Production Security
# ----------------------------
SECURE_SSL_REDIRECT=True
